<UserControl x:Class="FpsGodPc.App.Controls.BoostCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14">
        <StackPanel>
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="15"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Margin="0,6,0,10"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding TweakCountLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontSize="11"
                       Foreground="{StaticResource AccentBrush}"/>
            <Button Content="{Binding ApplyPresetLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Margin="0,12,0,0"
                    Height="34"
                    Background="{StaticResource AccentBrush}"
                    Foreground="{StaticResource VoidBrush}"
                    BorderBrush="{x:Null}"
                    Command="{Binding ApplyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding PresetId, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </StackPanel>
    </Border>
</UserControl>
