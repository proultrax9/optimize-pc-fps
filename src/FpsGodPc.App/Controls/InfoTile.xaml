<UserControl x:Class="FpsGodPc.App.Controls.InfoTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{StaticResource CardSheenBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="16,14">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Label, ElementName=Root}"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
            <TextBlock Text="{Binding Value, ElementName=Root}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       TextWrapping="Wrap"/>
            <TextBlock Text="{Binding Detail, ElementName=Root}"
                       Margin="0,4,0,0"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</UserControl>
