<UserControl x:Class="FpsGodPc.App.Controls.OcKnob"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="KnobArea" Grid.Row="0"
              Width="120" Height="120"
              Cursor="SizeNS">
            <!-- glow behind active knob -->
            <Ellipse Fill="{StaticResource GaugeGlowBrush}" Opacity="0.5" Margin="-8" IsHitTestVisible="False"/>
            <!-- outer ring -->
            <Ellipse Stroke="{StaticResource BorderStrongBrush}" StrokeThickness="2"
                     Fill="{StaticResource ElevatedBrush}"/>
            <!-- knurled inner body -->
            <Ellipse Margin="10" Fill="{StaticResource CardSheenBrush}"
                     Stroke="{StaticResource BorderBrush}" StrokeThickness="1"/>

            <!-- rotating pointer -->
            <Grid x:Name="PointerHost" RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
                <Grid.RenderTransform>
                    <RotateTransform x:Name="PointerRotate" Angle="-135"/>
                </Grid.RenderTransform>
                <Border Width="4" Height="22" CornerRadius="2"
                        Background="{StaticResource AccentBrush}"
                        VerticalAlignment="Top" HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        Effect="{StaticResource AccentGlowEffect}"/>
            </Grid>

            <!-- centre readout -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                <TextBlock x:Name="ValueText"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Name="SuffixText"
                           FontSize="10" FontWeight="Bold"
                           Foreground="{StaticResource MutedBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="KnobLabel"
                   Grid.Row="1" HorizontalAlignment="Center"
                   Margin="0,8,0,0"
                   FontSize="11" FontWeight="Bold"
                   Foreground="{StaticResource MutedBrush}"/>
    </Grid>
</UserControl>
