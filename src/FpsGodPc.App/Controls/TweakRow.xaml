<UserControl x:Class="FpsGodPc.App.Controls.TweakRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource CardSheenBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="18,15"
            Margin="0,0,0,8">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="14" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>
        <DockPanel LastChildFill="True">
            <!-- Toggle button (docked right) -->
            <Button DockPanel.Dock="Right"
                    Command="{Binding ToggleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    Width="112"
                    Height="38"
                    Margin="18,0,0,0"
                    VerticalAlignment="Center"
                    FontFamily="{StaticResource AppFont}"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Content" Value="Enable"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsToggled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                <Setter Property="Content" Value="Disable"/>
                                <Setter Property="Background" Value="{StaticResource ElevatedBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="BorderBrush" Value="{StaticResource AccentDeepBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Left: green active indicator bar + text -->
            <StackPanel VerticalAlignment="Center">
                <!-- Applied-state accent bar (visible when IsToggled=True) -->
                <Border x:Name="ActiveBar"
                        Width="3" Height="20"
                        CornerRadius="2"
                        Background="{StaticResource AccentBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,0,10,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Opacity" Value="0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsToggled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                    <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontFamily="{StaticResource AppFont}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <Border x:Name="RiskBadge"
                            Margin="10,0,0,0"
                            Padding="7,3"
                            CornerRadius="4"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding Risk, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontFamily="{StaticResource AppFont}"
                                   FontSize="10"
                                   FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           Margin="0,6,0,0"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="13"
                           LineHeight="19"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="720"/>
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
