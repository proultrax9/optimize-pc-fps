<UserControl x:Class="FpsGodPc.App.Controls.MetricTile"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{StaticResource CardSheenBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
        </Border.Effect>
        <StackPanel>
            <!-- Label row: UPPERCASE gray label + green accent dot -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                <Ellipse Width="6" Height="6"
                         Fill="{StaticResource AccentBrush}"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0"/>
                <TextBlock Text="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontFamily="{StaticResource AppFont}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Big metric value in mint green + DisplayFont -->
            <TextBlock Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       LineHeight="30"/>

            <!-- Sub-caption -->
            <TextBlock Text="{Binding Detail, RelativeSource={RelativeSource AncestorType=UserControl}}"
                       Margin="0,6,0,0"
                       FontFamily="{StaticResource AppFont}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap"/>

            <!-- Subtle green bottom accent line -->
            <Border Height="2" CornerRadius="1"
                    Background="{StaticResource AccentGlowBrush}"
                    Margin="0,12,0,0"
                    Opacity="0.4"/>
        </StackPanel>
    </Border>
</UserControl>
