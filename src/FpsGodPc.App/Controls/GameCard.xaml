<UserControl x:Class="FpsGodPc.App.Controls.GameCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border CornerRadius="14"
            Background="{StaticResource CardSheenBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="#FF000000" BlurRadius="18" ShadowDepth="0" Opacity="0.35"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="124"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Vector "banner": dark base + accent wash + big initial -->
            <Grid Grid.Row="0">
                <Rectangle Fill="{StaticResource SurfaceAltBrush}"/>
                <Rectangle Fill="{Binding AccentColor, ElementName=Root}" Opacity="0.22"/>
                <Rectangle Opacity="0.5">
                    <Rectangle.Fill>
                        <RadialGradientBrush GradientOrigin="0.3,0.2" Center="0.3,0.2" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#22FFFFFF" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <TextBlock x:Name="InitialText"
                           FontFamily="{StaticResource DisplayFont}"
                           FontSize="44" FontWeight="Black"
                           Foreground="{Binding AccentColor, ElementName=Root}"
                           Opacity="0.9"
                           HorizontalAlignment="Left" VerticalAlignment="Bottom"
                           Margin="16,0,0,8"/>
            </Grid>

            <!-- Footer -->
            <DockPanel Grid.Row="1" Margin="14,12,14,14">
                <Button DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Content="Optimize"
                        Style="{StaticResource PrimaryButton}"
                        Padding="14,8"
                        Command="{Binding Command, ElementName=Root}"
                        CommandParameter="{Binding CommandParameter, ElementName=Root}"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding GameName, ElementName=Root}"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding Status, ElementName=Root}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
