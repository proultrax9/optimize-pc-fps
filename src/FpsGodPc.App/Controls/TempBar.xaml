<UserControl x:Class="FpsGodPc.App.Controls.TempBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,6">
            <TextBlock x:Name="ValueText" DockPanel.Dock="Right"
                       FontFamily="{StaticResource DisplayFont}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock x:Name="BarLabel"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </DockPanel>

        <Border Grid.Row="1" x:Name="Track"
                Height="10" CornerRadius="5"
                Background="{StaticResource GaugeTrackBrush}">
            <Border x:Name="Fill"
                    HorizontalAlignment="Left"
                    CornerRadius="5"
                    Background="{StaticResource AccentBrush}"
                    Width="0"/>
        </Border>
    </Grid>
</UserControl>
