<UserControl x:Class="FpsGodPc.App.Controls.LiveGraph"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Grid x:Name="Host" ClipToBounds="True" MinHeight="56">
        <Path x:Name="AreaPath" IsHitTestVisible="False">
            <Path.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#5513F287" Offset="0"/>
                    <GradientStop Color="#0013F287" Offset="1"/>
                </LinearGradientBrush>
            </Path.Fill>
        </Path>
        <Polyline x:Name="Line"
                  Stroke="{StaticResource AccentBrush}"
                  StrokeThickness="2"
                  StrokeLineJoin="Round"
                  IsHitTestVisible="False"/>
    </Grid>
</UserControl>
