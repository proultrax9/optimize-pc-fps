<Window x:Class="FpsGodPc.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:FpsGodPc.App.ViewModels;assembly=FpsGodPc.ViewModels"
        Title="FPS Optimize GOD PC"
        Icon="pack://application:,,,/Assets/app.ico"
        MinWidth="1280"
        MinHeight="800"
        Width="1360"
        Height="860"
        Background="{StaticResource AppBgBrush}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="56"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Top navigation bar (merges title bar) -->
            <RowDefinition Height="56"/>
            <!-- Banners -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===================== TOP NAVIGATION BAR ===================== -->
        <Border Grid.Row="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True">

                <!-- Window caption buttons (far right) -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Top"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <!-- Minimize -->
                    <Button x:Name="BtnMinimize" Width="46" Height="56"
                            Click="BtnMinimize_Click" ToolTip="Minimize" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Maximize/Restore -->
                    <Button x:Name="BtnMaximize" Width="46" Height="56"
                            Click="BtnMaximize_Click" ToolTip="Maximize" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <!-- Close -->
                    <Button x:Name="BtnClose" Width="46" Height="56"
                            Click="BtnClose_Click" ToolTip="Close" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="Transparent">
                                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#CCC0392B"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Brand (left, draggable) -->
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="20,0,8,0">
                    <Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}"
                             Margin="0,0,10,0" VerticalAlignment="Center"
                             Effect="{StaticResource AccentGlowEffect}"/>
                    <TextBlock Text="FPS Optimize"
                               FontFamily="{StaticResource DisplayFont}" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text=" GOD PC"
                               FontFamily="{StaticResource DisplayFont}" FontSize="14" FontWeight="Light"
                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation tabs (fills remaining width, scrolls horizontally) -->
                <ScrollViewer VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Hidden"
                              Margin="18,0,8,0"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <ItemsControl ItemsSource="{Binding NavigationSections}" VerticalAlignment="Stretch">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavSectionViewModel}">
                                <!-- One section group of tabs -->
                                <ItemsControl ItemsSource="{Binding Items}" VerticalAlignment="Stretch" Margin="0,0,6,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:NavEntryViewModel}">
                                            <Button Background="Transparent" BorderThickness="0" Padding="0"
                                                    Cursor="Hand" VerticalAlignment="Stretch"
                                                    Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Key}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Border x:Name="pillBg" CornerRadius="8" Margin="3,10"
                                                                    Background="Transparent"/>
                                                            <TextBlock x:Name="navText" Text="{Binding Label}"
                                                                       FontFamily="{StaticResource AppFont}" FontSize="13"
                                                                       FontWeight="Medium" Margin="15,0"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                                            <!-- Active underline at the bottom of the bar -->
                                                            <Border x:Name="underline" Height="2" CornerRadius="1"
                                                                    Background="{StaticResource AccentBrush}"
                                                                    VerticalAlignment="Bottom" Margin="12,0"
                                                                    Visibility="Collapsed"/>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="pillBg" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                                                                <Setter TargetName="navText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter TargetName="navText" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                <Setter TargetName="navText" Property="FontWeight" Value="SemiBold"/>
                                                                <Setter TargetName="underline" Property="Visibility" Value="Visible"/>
                                                                <Setter TargetName="pillBg" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Admin banner -->
        <Border Grid.Row="1" Background="#22FBBF24" BorderBrush="#55FBBF24" BorderThickness="0,0,0,1" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock Text="{Binding AdminBannerText}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                        Content="{Binding RestartAdminLabel}"
                        Margin="12,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RestartElevatedCommand}"/>
            </DockPanel>
        </Border>

        <!-- Watchdog banner -->
        <Border Grid.Row="2" Background="#22F87171" BorderBrush="#55F87171" BorderThickness="0,0,0,1" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasWatchdogMessage}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding DismissWatchdogLabel}"
                        Margin="12,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissWatchdogCommand}"/>
                <TextBlock Text="{Binding WatchdogMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Confirm timer banner -->
        <Border Grid.Row="3" Background="#222A1F0A" BorderBrush="#55FBBF24" BorderThickness="0,0,0,1" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasConfirmTimer}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{Binding ConfirmTimerKeepLabel}"
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding KeepPendingTweaksCommand}"/>
                    <Button Content="{Binding ConfirmTimerRevertLabel}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RejectPendingTweaksCommand}"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConfirmTimerTitle}" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                    <TextBlock Text="{Binding ConfirmTimerMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===================== CONTENT AREA (full width) ===================== -->
        <Grid Grid.Row="4">
            <!-- Hero glow bloom at the very top of the content area -->
            <Rectangle VerticalAlignment="Top"
                       Height="280"
                       IsHitTestVisible="False"
                       Fill="{StaticResource HeroGlowBrush}"
                       Opacity="0.55"/>
            <!-- Page content (fade + slide-up transition driven from code-behind on each navigation) -->
            <ContentControl x:Name="PageHost"
                            Content="{Binding CurrentPage}"
                            RenderTransformOrigin="0.5,0.5">
                <ContentControl.RenderTransform>
                    <TranslateTransform x:Name="PageHostTransform" Y="0"/>
                </ContentControl.RenderTransform>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
