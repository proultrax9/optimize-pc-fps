<Window x:Class="FpsGodPc.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FpsGodPc.App.ViewModels;assembly=FpsGodPc.ViewModels"
        Title="FPS Optimize GOD PC"
        Icon="Assets/app.ico"
        MinWidth="1280"
        MinHeight="800"
        Width="1360"
        Height="860"
        Background="{StaticResource AppBgBrush}"
        FontFamily="{StaticResource AppFont}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#331F2937" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock Text="{Binding AdminBannerText}" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                        Content="{Binding RestartAdminLabel}"
                        Padding="12,6"
                        Margin="12,0,0,0"
                        Command="{Binding RestartElevatedCommand}"
                        Background="{StaticResource AccentMutedBrush}"
                        Foreground="{StaticResource TextBrush}"
                        BorderThickness="0"
                        Cursor="Hand"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1" Background="#332F1B4A" BorderBrush="{StaticResource DangerBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasWatchdogMessage}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding DismissWatchdogLabel}"
                        Padding="12,6"
                        Margin="12,0,0,0"
                        Command="{Binding DismissWatchdogCommand}"
                        Background="{StaticResource AccentMutedBrush}"
                        Foreground="{StaticResource TextBrush}"
                        BorderThickness="0"
                        Cursor="Hand"/>
                <TextBlock Text="{Binding WatchdogMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Background="#332A1F0A" BorderBrush="{StaticResource WarningBrush}" BorderThickness="0,0,0,1" Padding="16,10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasConfirmTimer}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{Binding ConfirmTimerKeepLabel}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            Command="{Binding KeepPendingTweaksCommand}"
                            Background="{StaticResource AccentBrush}"
                            Foreground="{StaticResource VoidBrush}"
                            BorderThickness="0"
                            Cursor="Hand"/>
                    <Button Content="{Binding ConfirmTimerRevertLabel}"
                            Padding="12,6"
                            Command="{Binding RejectPendingTweaksCommand}"
                            Background="{StaticResource AccentMutedBrush}"
                            Foreground="{StaticResource TextBrush}"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConfirmTimerTitle}" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                    <TextBlock Text="{Binding ConfirmTimerMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="14">
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,18">
                        <DockPanel LastChildFill="False">
                            <Border Width="18" Height="18" CornerRadius="4" Background="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                            <TextBlock Text="FPS Optimize"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="GOD PC v0.1.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="26,2,0,0"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding NavigationSections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NavSectionViewModel}">
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="10"
                                               FontWeight="Bold"
                                               Foreground="{StaticResource MutedBrush}"
                                               Margin="0,0,0,6">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFooter}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Title}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:NavEntryViewModel}">
                                                <Button Margin="0,2"
                                                        Padding="10,8"
                                                        HorizontalContentAlignment="Left"
                                                        Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding Key}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentMutedBrush}"/>
                                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="{Binding Label}"/>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel DockPanel.Dock="Bottom" Margin="0,16,0,0">
                        <TextBlock Text="{Binding LanguageLabel}" FontSize="10" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
                        <ComboBox ItemsSource="{Binding Languages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  Width="160"
                                  HorizontalAlignment="Left"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
