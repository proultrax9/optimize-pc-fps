<Window x:Class="FpsGodPc.App.Windows.ThemedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <Border Background="{StaticResource AppBgBrush}"
            BorderBrush="{StaticResource BorderStrongBrush}"
            BorderThickness="1"
            CornerRadius="16"
            Margin="18"
            MaxWidth="460">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="34" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>
        <Grid Margin="24,22,24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header (draggable) -->
            <StackPanel x:Name="Header" Grid.Row="0" Orientation="Horizontal"
                        Background="Transparent" MouseLeftButtonDown="Header_MouseDown">
                <Border x:Name="IconBadge" Width="34" Height="34" CornerRadius="10"
                        Background="{StaticResource AccentSoftBrush}"
                        VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock x:Name="IconGlyph" Text="i"
                               FontFamily="{StaticResource DisplayFont}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="TitleText" Style="{StaticResource DisplayM}"
                           VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
            </StackPanel>

            <!-- Message -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Margin="0,16,0,0"
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                       TextWrapping="Wrap" MaxWidth="400" LineHeight="20"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button x:Name="SecondaryBtn" Content="No" Style="{StaticResource SecondaryButton}"
                        MinWidth="92" Margin="0,0,10,0" Click="Secondary_Click" Visibility="Collapsed"/>
                <Button x:Name="PrimaryBtn" Content="OK" Style="{StaticResource GradientButton}"
                        MinWidth="110" Click="Primary_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
