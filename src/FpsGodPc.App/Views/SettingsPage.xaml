<UserControl x:Class="FpsGodPc.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,34" MaxWidth="960" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeroGlowBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24"
                    Margin="0,0,0,20"
                    Effect="{StaticResource AccentGlowEffect}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="CONTROL ROOM"
                                   Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="2,0,0,8"/>
                        <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource PageSubtitle}"
                                   MaxWidth="720"
                                   HorizontalAlignment="Left"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="{Binding VersionLabel}"
                                   Style="{StaticResource CaptionText}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding AppVersion}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontFamily="{StaticResource DisplayFont}"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="GENERAL" Style="{StaticResource LabelText}" Margin="2,0,0,10"/>
                    <Border Style="{StaticResource CardSurface}" Padding="18">
                        <StackPanel>
                            <CheckBox Content="{Binding CreateRestoreBeforeBoostLabel}"
                                      IsChecked="{Binding CreateRestoreBeforeBoost}"
                                      Margin="0,0,0,12"/>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                            <CheckBox Content="{Binding ConfirmExtremeTweaksLabel}"
                                      IsChecked="{Binding ConfirmExtremeTweaks}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="SAFETY GUARDIAN" Style="{StaticResource LabelText}" Margin="2,0,0,10"/>
                    <Border Style="{StaticResource CardSurface}" Padding="18">
                        <StackPanel>
                            <CheckBox Content="{Binding WatcherEnabledLabel}"
                                      IsChecked="{Binding WatcherEnabled}"
                                      Margin="0,0,0,12"/>
                            <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,0,0,12"/>
                            <CheckBox Content="{Binding BootAutoRevertLabel}"
                                      IsChecked="{Binding BootAutoRevert}"
                                      Margin="0,0,0,16"/>
                            <Border Background="{StaticResource SurfaceAltBrush}"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="14,12">
                                <DockPanel>
                                    <TextBlock Text="{Binding ConfirmTimerLabel}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,14,0"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBox Width="90"
                                             HorizontalAlignment="Right"
                                             Text="{Binding ConfirmTimerSecs, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14"
                    Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Content="{Binding SaveSettingsLabel}"
                            Command="{Binding SaveCommand}"
                            Style="{StaticResource GradientButton}"
                            MinWidth="160"
                            Padding="18,11"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Margin="16,0,0,0"
                               Foreground="{StaticResource AccentBrush}"
                               TextWrapping="Wrap"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="3">
                <TextBlock Text="ABOUT" Style="{StaticResource LabelText}" Margin="2,0,0,10"/>
                <Border Style="{StaticResource CardSurface}" Padding="18">
                    <StackPanel>
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,12"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding AppDataPrefix}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding DataDirectory}"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding GuardianDataPrefix}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding GuardianDirectory}"
                                           Foreground="{StaticResource TextBrush}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
