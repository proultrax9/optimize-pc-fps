<UserControl x:Class="FpsGodPc.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,14" Foreground="{StaticResource TextSecondaryBrush}"/>

            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="{Binding LanguageLabel}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                    <ComboBox Width="130" Margin="0,6,0,0" ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" />
                </StackPanel>
            </Border>

            <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <CheckBox Content="{Binding CreateRestoreBeforeBoostLabel}" IsChecked="{Binding CreateRestoreBeforeBoost}" Margin="0,0,0,6"/>
                    <CheckBox Content="{Binding ConfirmExtremeTweaksLabel}" IsChecked="{Binding ConfirmExtremeTweaks}" Margin="0,0,0,6"/>
                    <CheckBox Content="{Binding WatcherEnabledLabel}" IsChecked="{Binding WatcherEnabled}" Margin="0,0,0,6"/>
                    <CheckBox Content="{Binding BootAutoRevertLabel}" IsChecked="{Binding BootAutoRevert}" Margin="0,0,0,6"/>
                    <DockPanel>
                        <TextBlock Text="{Binding ConfirmTimerLabel}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Width="80" Text="{Binding ConfirmTimerSecs, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <Button Content="{Binding SaveSettingsLabel}" Width="130" Height="32" Command="{Binding SaveCommand}"
                    Background="{StaticResource AccentBrush}" Foreground="{StaticResource VoidBrush}" BorderBrush="{x:Null}" />

            <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,10" Foreground="{StaticResource AccentBrush}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding AppDataPrefix}" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding DataDirectory}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding GuardianDataPrefix}" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding GuardianDirectory}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="{Binding VersionLabel}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
