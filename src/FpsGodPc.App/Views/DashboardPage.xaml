<UserControl x:Class="FpsGodPc.App.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:FpsGodPc.App.Controls"
             xmlns:vm="clr-namespace:FpsGodPc.App.ViewModels;assembly=FpsGodPc.ViewModels">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeroGlowBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24"
                    Margin="0,0,0,22"
                    Effect="{StaticResource AccentGlowEffect}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="COMMAND CENTER"
                                   Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="2,0,0,8"/>
                        <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource PageSubtitle}"
                                   MaxWidth="760"
                                   HorizontalAlignment="Left"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1"
                            VerticalAlignment="Center"
                            Content="Boost Now"
                            Style="{StaticResource GradientButton}"
                            MinWidth="150"
                            Padding="20,12"
                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="boost"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.22*"/>
                    <ColumnDefinition Width="0.78*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardSurface}"
                        Padding="18,20"
                        Margin="0,0,18,0">
                    <StackPanel>
                        <DockPanel Margin="2,0,2,16">
                            <Border DockPanel.Dock="Right"
                                    Style="{StaticResource StatusChip}"
                                    Background="{StaticResource AccentSoftBrush}">
                                <TextBlock Foreground="{StaticResource AccentStrongBrush}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           FontWeight="Bold">
                                    <Run Text="{Binding CpuTemp, StringFormat={}{0:F0}}"/>
                                    <Run Text=" °C"/>
                                </TextBlock>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding LiveHardwareLabel}" Style="{StaticResource LabelText}"/>
                                <TextBlock Text="Realtime load, thermals, and memory pressure"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        <UniformGrid Columns="4">
                            <ctrl:RadialGauge Height="158"
                                              Margin="5,0"
                                              Label="CPU"
                                              Unit="%"
                                              AutoColor="True"
                                              Maximum="100"
                                              StrokeThickness="10"
                                              Value="{Binding CpuUsage}"/>
                            <ctrl:RadialGauge Height="158"
                                              Margin="5,0"
                                              Label="GPU"
                                              Unit="%"
                                              AutoColor="True"
                                              Maximum="100"
                                              StrokeThickness="10"
                                              Value="{Binding GpuUsage}"/>
                            <ctrl:RadialGauge Height="158"
                                              Margin="5,0"
                                              Label="MEMORY"
                                              Unit="%"
                                              AutoColor="True"
                                              Maximum="100"
                                              StrokeThickness="10"
                                              Value="{Binding RamUsage}"/>
                            <ctrl:RadialGauge Height="158"
                                              Margin="5,0"
                                              Label="CPU TEMP"
                                              Unit="°C"
                                              AutoColor="True"
                                              Maximum="100"
                                              StrokeThickness="10"
                                              Value="{Binding CpuTemp}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardSurface}" Padding="18,18">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,14">
                            <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                           FontFamily="{StaticResource DisplayFont}"
                                           FontSize="20"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right">
                                    <Run Text="{Binding CpuUsage, StringFormat={}{0:F0}}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                                <TextBlock Text="CPU"
                                           Foreground="{StaticResource MutedBrush}"
                                           FontFamily="{StaticResource MonoFont}"
                                           FontSize="11"
                                           HorizontalAlignment="Right"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="CPU Activity" Style="{StaticResource CardHeading}"/>
                                <TextBlock Text="Last sampled utilization curve"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                        <Border Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="10">
                            <ctrl:LiveGraph Height="132" Maximum="100" Values="{Binding CpuHistory}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding LiveMetrics}" Margin="0,0,0,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MetricItem}">
                        <ctrl:MetricTile Label="{Binding Label}"
                                         Value="{Binding Value}"
                                         Detail="{Binding Detail}"
                                         Margin="0,0,12,12"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <WrapPanel Grid.Row="3" Margin="0,0,0,10">
                <ctrl:MetricTile Margin="0,0,12,12"
                                 Label="{Binding PerformanceScoreLabel}"
                                 Value="{Binding PerformanceScore}"
                                 Detail="{Binding PerformanceScoreDetail}"/>
                <ctrl:MetricTile Margin="0,0,12,12"
                                 Label="{Binding SafetyScoreLabel}"
                                 Value="{Binding SafetyScore}"
                                 Detail="{Binding SafetyScoreDetail}"/>
                <ctrl:MetricTile Margin="0,0,12,12"
                                 Label="{Binding PowerPlanLabel}"
                                 Value="{Binding PowerPlan}"
                                 Detail="{Binding PowerPlanDetail}"/>
                <ctrl:MetricTile Margin="0,0,0,12"
                                 Label="{Binding GameModeLabel}"
                                 Value="{Binding GameMode}"
                                 Detail="{Binding GameModeDetail}"/>
            </WrapPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="{Binding SystemDetailsLabel}" Style="{StaticResource LabelText}" Margin="2,0,0,12"/>
                <ItemsControl ItemsSource="{Binding SystemMetrics}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:MetricItem}">
                            <ctrl:InfoTile Width="300"
                                           Label="{Binding Label}"
                                           Value="{Binding Value}"
                                           Detail="{Binding Detail}"
                                           Margin="0,0,12,12"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
