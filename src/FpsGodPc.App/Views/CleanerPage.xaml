<UserControl x:Class="FpsGodPc.App.Views.CleanerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="20">
        <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
        <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,14" Foreground="{StaticResource TextSecondaryBrush}"/>
        <CheckBox Content="{Binding TempFilesLabel}" IsChecked="{Binding TempFiles}" Margin="0,4"/>
        <CheckBox Content="{Binding ShaderCacheLabel}" IsChecked="{Binding ShaderCache}" Margin="0,4"/>
        <CheckBox Content="{Binding DnsCacheLabel}" IsChecked="{Binding DnsCache}" Margin="0,4"/>
        <CheckBox Content="{Binding RecycleBinLabel}" IsChecked="{Binding RecycleBin}" Margin="0,4"/>
        <Button Content="{Binding RunCleanerLabel}" Command="{Binding RunCleanerCommand}" Margin="0,16,0,0" HorizontalAlignment="Left" Padding="14,8" Background="{StaticResource AccentBrush}" Foreground="{StaticResource VoidBrush}" BorderThickness="0"/>
        <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0" Foreground="{StaticResource AccentBrush}"/>
    </StackPanel>
</UserControl>
