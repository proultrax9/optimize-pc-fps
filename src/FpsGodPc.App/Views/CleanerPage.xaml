<UserControl x:Class="FpsGodPc.App.Views.CleanerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:FpsGodPc.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <ctrl:PageHeader Eyebrow="CLEANER" Title="{Binding Title}" Subtitle="{Binding Subtitle}" Margin="0,0,0,18"/>

            <Border Style="{StaticResource CardSurface}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="SELECT TARGETS" Style="{StaticResource SectionLabel}" Margin="0,0,0,10"/>
                    <TextBlock Text="Choose what to clean, then run the cleaner."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap"/>
                    <CheckBox Content="{Binding TempFilesLabel}" IsChecked="{Binding TempFiles}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding ShaderCacheLabel}" IsChecked="{Binding ShaderCache}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding DnsCacheLabel}" IsChecked="{Binding DnsCache}" Margin="0,0,0,8"/>
                    <CheckBox Content="{Binding RecycleBinLabel}" IsChecked="{Binding RecycleBin}" Margin="0,0,0,4"/>
                    <Button Content="{Binding RunCleanerLabel}" Command="{Binding RunCleanerCommand}"
                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,18,0,0" MinWidth="180" FontSize="14"/>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,14,0,0"
                               Foreground="{StaticResource AccentBrush}" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
