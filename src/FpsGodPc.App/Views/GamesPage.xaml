<UserControl x:Class="FpsGodPc.App.Views.GamesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:FpsGodPc.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeroGlowBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24"
                    Margin="0,0,0,20"
                    Effect="{StaticResource AccentGlowEffect}">
                <StackPanel>
                    <TextBlock Text="GAME PROFILES"
                               Style="{StaticResource LabelText}"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="2,0,0,8"/>
                    <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="{Binding Subtitle}"
                               Style="{StaticResource PageSubtitle}"
                               MaxWidth="760"
                               HorizontalAlignment="Left"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource CardSurface}"
                    Padding="16,18"
                    Margin="0,0,0,18">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ctrl:GameCard Width="254"
                                           Margin="0,0,16,16"
                                           GameName="{Binding Name}"
                                           Status="{Binding Executable}"
                                           Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding Id}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardSurface}" Padding="22">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,24,0">
                        <TextBlock Text="{Binding SelectedGame.Name}" Style="{StaticResource DisplayM}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,14">
                            <Border Style="{StaticResource StatusChip}"
                                    Background="{StaticResource AccentSoftBrush}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="{Binding InstallStatus}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="11"
                                           FontWeight="Bold"/>
                            </Border>
                            <Border Style="{StaticResource StatusChip}">
                                <TextBlock Text="{Binding PriorityDisplay}"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="11"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedGame.InstallPath}"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Grid.Row="0"
                            VerticalAlignment="Top"
                            Content="{Binding ApplyProfileLabel}"
                            Style="{StaticResource GradientButton}"
                            MinWidth="160"
                            Padding="18,11"
                            Command="{Binding ApplyProfileCommand}"/>

                    <Grid Grid.ColumnSpan="2" Grid.Row="1" Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.95*"/>
                            <ColumnDefinition Width="1.05*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="16"
                                Margin="0,0,16,0">
                            <StackPanel>
                                <TextBlock Text="PROFILE TARGETS"
                                           Style="{StaticResource LabelText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,0,12"/>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding FpsCapPrefix}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding SelectedGame.FpsCap}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontFamily="{StaticResource DisplayFont}"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                                <DockPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding PriorityPrefix}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding PriorityDisplay}"
                                               Foreground="{StaticResource TextBrush}"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Right"/>
                                </DockPanel>
                                <StackPanel>
                                    <TextBlock Text="{Binding LaunchOptionsPrefix}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,0,0,6"/>
                                    <Border Background="{StaticResource VoidBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,8">
                                        <TextBlock Text="{Binding SelectedGame.LaunchOptions}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   TextWrapping="Wrap"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Background="{StaticResource SurfaceAltBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="16">
                            <StackPanel>
                                <TextBlock Text="PROFILE NOTES"
                                           Style="{StaticResource LabelText}"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,0,12"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Border DockPanel.Dock="Left"
                                            Width="6"
                                            Height="6"
                                            CornerRadius="3"
                                            Background="{StaticResource AccentBrush}"
                                            VerticalAlignment="Top"
                                            Margin="0,6,10,0"/>
                                    <TextBlock Text="{Binding GameNotes}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </DockPanel>
                                <TextBlock Text="{Binding SelectHint}"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ShowSelectHint, Converter={StaticResource BoolToVis}}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
