<UserControl x:Class="FpsGodPc.App.Views.GamesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,12" Foreground="{StaticResource TextSecondaryBrush}"/>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Games}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,0,6"
                                    Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Id}">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Executable}" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <Border Grid.Column="2" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
            <StackPanel>
                <TextBlock Text="{Binding SelectedGame.Name}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="{Binding InstallStatus}" Margin="0,4,0,4" Foreground="{StaticResource AccentBrush}" FontSize="11"/>
                <TextBlock Text="{Binding SelectedGame.InstallPath}" Margin="0,0,0,10" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                <Button Content="{Binding ApplyProfileLabel}" Command="{Binding ApplyProfileCommand}" HorizontalAlignment="Left" Margin="0,0,0,10"
                        Background="{StaticResource AccentBrush}" Foreground="{StaticResource VoidBrush}" BorderThickness="0" Padding="12,6"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding FpsCapPrefix}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding SelectedGame.FpsCap}" Foreground="{StaticResource TextBrush}" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{Binding PriorityPrefix}" Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding PriorityDisplay}" Foreground="{StaticResource TextBrush}" Margin="4,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="{Binding LaunchOptionsPrefix}" Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="{Binding SelectedGame.LaunchOptions}" Foreground="{StaticResource AccentBrush}" Margin="4,0,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <TextBlock Text="{Binding SelectHint}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"
                           Visibility="{Binding ShowSelectHint, Converter={StaticResource BoolToVis}}"/>
                <ItemsControl ItemsSource="{Binding GameNotes}" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
