<UserControl x:Class="FpsGodPc.App.Views.ScannerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FpsGodPc.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <controls:PageHeader Eyebrow="SCANNER" Title="{Binding Title}" Subtitle="{Binding Subtitle}" Margin="0,0,0,18">
                <controls:PageHeader.Action>
                    <Button Content="{Binding RunScanLabel}" MinWidth="150" Style="{StaticResource GradientButton}" Command="{Binding RunScanCommand}"/>
                </controls:PageHeader.Action>
            </controls:PageHeader>

            <WrapPanel Margin="0,0,0,16">
                <controls:MetricTile Margin="0,0,10,10" Label="{Binding FpsGainLabel}" Value="{Binding FpsGain}"/>
                <controls:MetricTile Margin="0,0,10,10" Label="{Binding LatencyGainLabel}" Value="{Binding LatencyGain}"/>
                <controls:MetricTile Margin="0,0,10,10" Label="{Binding StabilityRiskLabel}" Value="{Binding StabilityRisk}"/>
                <controls:MetricTile Margin="0,0,0,10" Label="{Binding RecommendedLabel}" Value="{Binding RecommendedMode}" Detail="{Binding PerformanceScore}"/>
            </WrapPanel>

            <Button Content="{Binding ApplyRecommendedLabel}" Command="{Binding ApplyRecommendedCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,0,0,16"/>

            <TextBlock Text="FINDINGS" Style="{StaticResource SectionLabel}"/>
            <ItemsControl ItemsSource="{Binding Findings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardSurface}" Margin="0,0,0,10" Padding="14">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                <TextBlock Text="{Binding Detail}" Margin="0,4,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Recommendation}" Margin="0,6,0,0" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
