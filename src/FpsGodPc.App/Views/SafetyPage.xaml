<UserControl x:Class="FpsGodPc.App.Views.SafetyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,14" Foreground="{StaticResource TextSecondaryBrush}"/>
            <TextBlock Text="{Binding AppliedSummary}" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{Binding KnownGoodSummary}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,12"/>
            <Border Background="#331F2937" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasPendingRevert}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="{Binding PendingRevertKeepLabel}" Command="{Binding KeepPendingTweaksCommand}" Margin="0,0,8,0" Padding="10,4"/>
                        <Button Content="{Binding PendingRevertRevertLabel}" Command="{Binding RejectPendingTweaksCommand}" Padding="10,4"/>
                    </StackPanel>
                    <TextBlock Text="{Binding PendingRevertMessage}" TextWrapping="Wrap" Foreground="{StaticResource WarningBrush}"/>
                </DockPanel>
            </Border>
            <WrapPanel Margin="0,0,0,12">
                <Button Content="{Binding CreateSnapshotLabel}" Command="{Binding CreateSnapshotCommand}" Margin="0,0,8,0" Padding="12,6"/>
                <Button Content="{Binding RollbackAllLabel}" Command="{Binding RollbackAllCommand}" Margin="0,0,8,0" Padding="12,6"/>
                <Button Content="{Binding DismissWatchdogLabel}" Command="{Binding DismissWatchdogCommand}" Padding="12,6"/>
            </WrapPanel>
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" Margin="0,0,0,10"/>
            <TextBlock Text="{Binding GuardianTweaksLabel}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding GuardianTweaks}" Margin="0,0,0,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,6">
                            <DockPanel>
                                <Button Content="{Binding IsEnabled, Converter={StaticResource BoolToEnableLabelConverter}}"
                                        Command="{Binding ToggleCommand}" DockPanel.Dock="Right" Padding="10,4" Margin="8,0,0,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                    <TextBlock Text="{Binding RiskLabel}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Text="{Binding SnapshotsSectionLabel}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
            <DataGrid ItemsSource="{Binding Snapshots}" AutoGenerateColumns="False" HeadersVisibility="Column" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding DataContext.GridIdHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Id}" Width="*"/>
                    <DataGridTextColumn Header="{Binding DataContext.GridLabelHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Label}" Width="2*"/>
                    <DataGridTextColumn Header="{Binding DataContext.GridTakenHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding TakenAt}" Width="2*"/>
                    <DataGridCheckBoxColumn Header="{Binding DataContext.GridKnownGoodHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CommittedKnownGood}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
