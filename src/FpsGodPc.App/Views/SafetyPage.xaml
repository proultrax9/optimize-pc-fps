<UserControl x:Class="FpsGodPc.App.Views.SafetyPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:FpsGodPc.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <ctrl:PageHeader Eyebrow="SAFETY" Title="{Binding Title}" Subtitle="{Binding Subtitle}" Margin="0,0,0,18"/>

            <!-- Summary + actions -->
            <Border Style="{StaticResource CardSurface}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding AppliedSummary}" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding KnownGoodSummary}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>

                    <!-- Pending revert warning -->
                    <Border Background="#222A1F0A" BorderBrush="{StaticResource WarningBrush}" BorderThickness="1"
                            CornerRadius="10" Padding="14" Margin="0,14,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPendingRevert}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                <Button Content="{Binding PendingRevertKeepLabel}" Command="{Binding KeepPendingTweaksCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                                <Button Content="{Binding PendingRevertRevertLabel}" Command="{Binding RejectPendingTweaksCommand}" Style="{StaticResource SecondaryButton}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding PendingRevertMessage}" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="{StaticResource WarningBrush}"/>
                        </DockPanel>
                    </Border>

                    <WrapPanel Margin="0,16,0,0">
                        <Button Content="{Binding CreateSnapshotLabel}" Command="{Binding CreateSnapshotCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,10,0"/>
                        <Button Content="{Binding RollbackAllLabel}" Command="{Binding RollbackAllCommand}" Style="{StaticResource DangerButton}" Margin="0,0,10,0"/>
                        <Button Content="{Binding DismissWatchdogLabel}" Command="{Binding DismissWatchdogCommand}" Style="{StaticResource SecondaryButton}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentBrush}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Guardian tweaks -->
            <TextBlock Text="{Binding GuardianTweaksLabel}" Style="{StaticResource SectionLabel}"/>
            <ItemsControl ItemsSource="{Binding GuardianTweaks}" Margin="0,0,0,18">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardSurface}" Padding="16,12" Margin="0,0,0,8">
                            <DockPanel>
                                <Button Content="{Binding IsEnabled, Converter={StaticResource BoolToEnableLabelConverter}}"
                                        Command="{Binding ToggleCommand}" DockPanel.Dock="Right"
                                        Style="{StaticResource SecondaryButton}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" Style="{StaticResource CardHeading}"/>
                                    <TextBlock Text="{Binding RiskLabel}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Snapshots -->
            <TextBlock Text="{Binding SnapshotsSectionLabel}" Style="{StaticResource SectionLabel}"/>
            <DataGrid ItemsSource="{Binding Snapshots}" AutoGenerateColumns="False" HeadersVisibility="Column" RowHeaderWidth="0" MaxHeight="320">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding DataContext.GridIdHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Id}" Width="*"/>
                    <DataGridTextColumn Header="{Binding DataContext.GridLabelHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding Label}" Width="2*"/>
                    <DataGridTextColumn Header="{Binding DataContext.GridTakenHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding TakenAt}" Width="2*"/>
                    <DataGridCheckBoxColumn Header="{Binding DataContext.GridKnownGoodHeader, RelativeSource={RelativeSource AncestorType=UserControl}}" Binding="{Binding CommittedKnownGood}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
