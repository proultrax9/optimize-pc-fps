<UserControl x:Class="FpsGodPc.App.Views.BoostPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FpsGodPc.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="28,24,28,34">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource HeroGlowBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24"
                    Margin="0,0,0,18"
                    Effect="{StaticResource AccentGlowEffect}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="OPTIMIZE"
                                   Style="{StaticResource LabelText}"
                                   Foreground="{StaticResource AccentBrush}"
                                   Margin="2,0,0,8"/>
                        <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   Style="{StaticResource PageSubtitle}"
                                   MaxWidth="720"
                                   HorizontalAlignment="Left"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="24,0,0,0">
                        <Button Content="{Binding OpenTweaksLabel}"
                                Command="{Binding OpenTweaksCommand}"
                                Style="{StaticResource SecondaryButton}"
                                MinWidth="148"
                                Padding="16,10"/>
                        <Button Command="{Binding RestartAsAdminCommand}"
                                Margin="0,10,0,0"
                                MinWidth="148"
                                Padding="16,10"
                                Content="{Binding RestartAsAdminLabel}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource GradientButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{StaticResource SurfaceAltBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="14,12"
                    Margin="0,0,0,18">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusMessage}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <Border DockPanel.Dock="Left"
                            Width="8"
                            Height="8"
                            CornerRadius="4"
                            Background="{StaticResource SuccessBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Effect="{StaticResource AccentGlowEffect}"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <ItemsControl Grid.Row="2" ItemsSource="{Binding Presets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:BoostCard Preset="{Binding}"
                                            ApplyCommand="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            MoreTweaksLabel="{Binding DataContext.MoreTweaksLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            RestoreRecommendedLabel="{Binding DataContext.RestoreRecommendedLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Margin="0,0,16,16"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
