<Window x:Class="FpsGodPc.App.Windows.ExpertChecklistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Expert Guide"
        Width="720"
        Height="640"
        MinWidth="600"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource AppBgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource AppFont}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock x:Name="TitleText" FontSize="22" FontWeight="Bold"/>
            <TextBlock x:Name="WaivedText" Margin="0,6,0,0" Foreground="{StaticResource SuccessBrush}" Visibility="Collapsed"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="GuidesList"/>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button x:Name="WaiveButton" Padding="14,8" Margin="0,0,8,0" Click="WaiveButton_Click"/>
            <Button x:Name="CompleteButton" Padding="14,8" Margin="0,0,8,0" Click="CompleteButton_Click"/>
            <Button x:Name="CloseButton" Padding="14,8" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
