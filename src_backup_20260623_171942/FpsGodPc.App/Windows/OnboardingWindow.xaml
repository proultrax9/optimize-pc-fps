<Window x:Class="FpsGodPc.App.Windows.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Safety Guardian"
        Width="480"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource AppBgBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="{StaticResource AppFont}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="TitleText" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
        <ItemsControl x:Name="BulletsList" Grid.Row="1" Margin="0,16,0,16"/>
        <Button x:Name="GotItButton" Grid.Row="2" Height="40" Click="GotItButton_Click"
                Background="{StaticResource AccentBrush}" Foreground="{StaticResource VoidBrush}" BorderThickness="0"/>
    </Grid>
</Window>
