<UserControl x:Class="FpsGodPc.App.Controls.BoostCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:FpsGodPc.Core.Models;assembly=FpsGodPc.Core">
    <Border Background="{StaticResource CardBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Preset.Name, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextBrush}"/>
                            <Border x:Name="RiskBadge"
                                    Margin="8,0,0,0"
                                    Padding="6,2"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding Preset.RiskLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           FontSize="10"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Preset.Description, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   Margin="0,2,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Width="36"
                            Height="36"
                            CornerRadius="6"
                            Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource AccentMutedBrush}"
                            BorderThickness="1">
                        <Viewbox Width="16" Height="16" Margin="8">
                            <Path Fill="{StaticResource AccentBrush}"
                                  Data="M13,2 L3,14 H12 L11,22 L21,10 H12 Z"
                                  Stretch="Uniform"/>
                        </Viewbox>
                    </Border>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="20,16">
                <TextBlock Text="{Binding Preset.IncludesLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,0,0,12"/>

                <ItemsControl ItemsSource="{Binding Preset.TweakNames, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Path Data="M20,6 L9,17 L4,12"
                                      Stroke="{StaticResource AccentBrush}"
                                      StrokeThickness="2"
                                      Width="12"
                                      Height="12"
                                      Stretch="Uniform"
                                      Margin="0,1,8,0"/>
                                <TextBlock Text="{Binding}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Margin="20,0,0,0"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Preset.MoreTweakCount, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="+"/>
                    <Run Text="{Binding Preset.MoreTweakCount, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                    <Run Text="{Binding MoreTweaksLabel, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
                </TextBlock>

                <Border Margin="0,16,0,0"
                        Padding="12,8"
                        CornerRadius="6"
                        Background="#0DFBBF24"
                        BorderBrush="#33FBBF24"
                        BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M12,2 L2,20 H9 L8,22 L22,10 H15 Z"
                              Fill="{StaticResource WarningBrush}"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Margin="0,2,8,0"/>
                        <TextBlock Text="{Binding Preset.Warning, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="16"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="20,12">
                <StackPanel>
                    <Button HorizontalAlignment="Stretch"
                            Height="40"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Command="{Binding ApplyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Preset.Id, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="btnRoot"
                                                    CornerRadius="6"
                                                    Padding="0,10"
                                                    Background="{StaticResource AccentBrush}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="btnRoot" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="btnRoot" Property="Opacity" Value="0.5"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding Preset.IsAdvisorOnly, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                    <Setter TargetName="btnRoot" Property="Background" Value="{StaticResource ElevatedBrush}"/>
                                                    <Setter TargetName="btnRoot" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Setter TargetName="btnRoot" Property="BorderThickness" Value="1"/>
                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="Foreground" Value="{StaticResource VoidBrush}"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Content" Value="{Binding Preset.ApplyButtonLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                            </Style>
                        </Button.Style>
                    </Button>
                    <TextBlock Text="{Binding RestoreRecommendedLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Margin="0,8,0,0"
                               FontSize="10"
                               Foreground="{StaticResource WarningBrush}"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Preset.RequiresRestorePoint, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
