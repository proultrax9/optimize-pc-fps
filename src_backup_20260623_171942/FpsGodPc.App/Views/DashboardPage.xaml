<UserControl x:Class="FpsGodPc.App.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FpsGodPc.App.Controls"
             xmlns:vm="clr-namespace:FpsGodPc.App.ViewModels;assembly=FpsGodPc.ViewModels">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="{Binding Title}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="{Binding Subtitle}" Margin="0,4,0,14" Foreground="{StaticResource TextSecondaryBrush}"/>

            <WrapPanel Margin="0,0,0,14">
                <controls:MetricTile Margin="0,0,10,0" Label="{Binding PerformanceScoreLabel}" Value="{Binding PerformanceScore}" Detail="{Binding PowerPlan}"/>
                <controls:MetricTile Margin="0,0,10,0" Label="{Binding SafetyScoreLabel}" Value="{Binding SafetyScore}" Detail="{Binding SafetyScoreDetail}"/>
                <controls:MetricTile Margin="0,0,10,0" Label="{Binding PowerPlanLabel}" Value="{Binding PowerPlan}" Detail="{Binding PowerPlanDetail}"/>
                <controls:MetricTile Label="{Binding GameModeLabel}" Value="{Binding GameMode}" Detail="{Binding GameModeDetail}"/>
            </WrapPanel>

            <TextBlock Text="{Binding LiveHardwareLabel}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding LiveMetrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MetricItem}">
                        <controls:MetricTile Label="{Binding Label}" Value="{Binding Value}" Detail="{Binding Detail}" Margin="0,0,10,10"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding SystemDetailsLabel}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Margin="0,8,0,8"/>
            <ItemsControl ItemsSource="{Binding SystemMetrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MetricItem}">
                        <controls:MetricTile Label="{Binding Label}" Value="{Binding Value}" Detail="{Binding Detail}" Margin="0,0,10,10"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
