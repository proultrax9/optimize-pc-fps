<UserControl x:Class="FpsGodPc.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitle}"/>

            <Border Style="{StaticResource CardSurface}" Margin="0,0,0,10">
                <StackPanel>
                    <CheckBox Content="{Binding CreateRestoreBeforeBoostLabel}" IsChecked="{Binding CreateRestoreBeforeBoost}"/>
                    <CheckBox Content="{Binding ConfirmExtremeTweaksLabel}" IsChecked="{Binding ConfirmExtremeTweaks}"/>
                    <CheckBox Content="{Binding WatcherEnabledLabel}" IsChecked="{Binding WatcherEnabled}"/>
                    <CheckBox Content="{Binding BootAutoRevertLabel}" IsChecked="{Binding BootAutoRevert}" Margin="0,0,0,0"/>
                    <DockPanel Margin="0,14,0,0">
                        <TextBlock Text="{Binding ConfirmTimerLabel}" VerticalAlignment="Center" Margin="0,0,12,0"
                                   Foreground="{StaticResource TextBrush}" FontWeight="SemiBold"/>
                        <TextBox Width="80" Text="{Binding ConfirmTimerSecs, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </StackPanel>
            </Border>

            <Button Content="{Binding SaveSettingsLabel}" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" MinWidth="140"/>

            <TextBlock Text="{Binding StatusMessage}" Margin="0,10,0,10" Foreground="{StaticResource AccentBrush}" />
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding AppDataPrefix}" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding DataDirectory}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding GuardianDataPrefix}" Foreground="{StaticResource TextSecondaryBrush}"/>
                <TextBlock Text="{Binding GuardianDirectory}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                <TextBlock Text="{Binding VersionLabel}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding AppVersion}" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
