<UserControl x:Class="FpsGodPc.App.Views.NetworkPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitle}"/>

            <!-- ===================== POWER PLAN GOD MODE ===================== -->
            <Border Margin="0,0,0,18"
                    BorderBrush="{StaticResource BorderStrongBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Background="{StaticResource CardBrush}">
                <Grid>
                    <Border CornerRadius="16" Background="{StaticResource HeroGlowBrush}"/>
                    <Grid Margin="22,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource AccentGradientBrush}">
                                    <TextBlock Text="⚡" FontSize="18" Foreground="#FFFFFFFF"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Power Plan God Mode" Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>

                            <TextBlock Margin="0,10,0,12"
                                       MaxWidth="560" HorizontalAlignment="Left"
                                       TextWrapping="Wrap"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Maximum performance power plan: CPU at 100%, sleep disabled, and your display will never turn off automatically while God Mode is active. Run as Administrator."/>

                            <!-- Status chip -->
                            <Border x:Name="powerChip">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse x:Name="powerDot" Width="8" Height="8" VerticalAlignment="Center"
                                             Fill="{StaticResource TextSecondaryBrush}"/>
                                    <TextBlock Text="{Binding PowerPlanStatus}" Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}"/>
                                </StackPanel>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusChip}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPowerGodModeActive}" Value="True">
                                                <Setter Property="Background" Value="#2634D399"/>
                                                <Setter Property="BorderBrush" Value="#5534D399"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                            </Border>
                        </StackPanel>

                        <Button Grid.Column="1"
                                VerticalAlignment="Center"
                                MinWidth="180"
                                Padding="22,12"
                                FontSize="14"
                                Style="{StaticResource PrimaryButton}"
                                Content="{Binding GodModePowerPlanLabel}"
                                Command="{Binding ApplyGodModePowerPlanCommand}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- ===================== QUICK ACTIONS ===================== -->
            <TextBlock Text="QUICK ACTIONS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardSurface}" Margin="0,0,0,18">
                <StackPanel>
                    <WrapPanel>
                        <Button Content="{Binding FlushDnsLabel}" Command="{Binding FlushDnsCommand}"
                                Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                        <Button Content="{Binding TuneAdapterLabel}" Command="{Binding TuneAdapterCommand}"
                                Style="{StaticResource SecondaryButton}"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding StatusMessage}" Margin="0,12,0,0"
                               Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ===================== LATENCY TEST ===================== -->
            <TextBlock Text="LATENCY TEST" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardSurface}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <Button DockPanel.Dock="Right"
                                Content="{Binding PingTestLabel}"
                                MinWidth="110" Margin="10,0,0,0"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding RunPingCommand}"/>
                        <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"/>
                    </DockPanel>

                    <Border Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="10" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding HostPrefix}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding PingHost}" Margin="0,4,0,0" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding LatencyPrefix}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding PingLatency}" Margin="0,4,0,0" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding PacketLossPrefix}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding PingPacketLoss}" Margin="0,4,0,0" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="{Binding PingMessage}" Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
