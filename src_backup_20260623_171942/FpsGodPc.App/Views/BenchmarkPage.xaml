<UserControl x:Class="FpsGodPc.App.Views.BenchmarkPage"
             x:Name="PageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24,28,28">
            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}"/>
            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource PageSubtitle}"/>

            <!-- 3D Heaven / Superposition hero -->
            <Border Margin="0,0,0,18" BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"
                    CornerRadius="16" Background="{StaticResource CardBrush}">
                <Grid>
                    <Border CornerRadius="16" Background="{StaticResource HeroGlowBrush}" IsHitTestVisible="False"/>
                    <Grid Margin="22,20" Panel.ZIndex="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource AccentGradientBrush}">
                                    <TextBlock Text="🚀" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="3D Space Battle Benchmark" Margin="12,0,0,0" VerticalAlignment="Center"
                                           FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
                            </StackPanel>
                            <TextBlock Margin="0,10,0,10" MaxWidth="560" TextWrapping="Wrap" FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="Uses Hypertune Space Battle when installed. Otherwise downloads from GitHub or Unigine Heaven. Auto-runs 60s and saves FPS."/>
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusChip}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHeavenReady}" Value="True">
                                                <Setter Property="Background" Value="#2634D399"/>
                                                <Setter Property="BorderBrush" Value="#5534D399"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding HeavenStatus}" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button Content="{Binding RunBenchmarkLabel}"
                                    Command="{Binding RunBenchmarkCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="220"
                                    Padding="22,12"
                                    FontSize="14"
                                    FontWeight="SemiBold"/>
                            <TextBlock Margin="0,10,0,0" MaxWidth="220" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding StatusMessage}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <TextBlock Text="SESSION OPTIONS" Style="{StaticResource SectionLabel}"/>
            <Border Style="{StaticResource CardSurface}" Margin="0,0,0,14">
                <WrapPanel>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="{Binding LabelFieldLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox Width="240" Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="{Binding DurationLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        <TextBox Width="90" Text="{Binding DurationSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <TextBlock Text="{Binding CompareSummary}" Margin="0,0,0,8" Foreground="{StaticResource AccentBrush}" FontSize="12" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding StatusMessage}" Margin="0,0,0,12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>

            <TextBlock Text="HISTORY" Style="{StaticResource SectionLabel}"/>
            <DataGrid x:Name="HistoryGrid" ItemsSource="{Binding Sessions}" MaxHeight="320" MinHeight="120"
                      HeadersVisibility="Column" RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Label" Binding="{Binding Label}" Width="1.4*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding TakenAt}" Width="1.6*"/>
                    <DataGridTextColumn Header="Duration" Binding="{Binding DurationSecs}" Width="0.65*"/>
                    <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="0.85*"/>
                    <DataGridTextColumn Header="Avg FPS" Binding="{Binding AvgFps, Converter={StaticResource NullableFpsConverter}}" Width="0.75*"/>
                    <DataGridTextColumn Header="1% Low" Binding="{Binding Pct1Low, Converter={StaticResource NullableFpsConverter}}" Width="0.75*"/>
                    <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="2.2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
