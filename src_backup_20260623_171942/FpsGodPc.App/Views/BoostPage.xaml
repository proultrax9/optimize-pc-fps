<UserControl x:Class="FpsGodPc.App.Views.BoostPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FpsGodPc.App.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,32">
            <!-- Page header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Title}"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}"/>
                    <TextBlock Text="{Binding Subtitle}"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="640"
                               HorizontalAlignment="Left"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="{Binding OpenTweaksLabel}"
                        VerticalAlignment="Top"
                        Command="{Binding OpenTweaksCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,6"
                        FontSize="12"/>
            </Grid>

            <Button HorizontalAlignment="Left"
                    Command="{Binding RestartAsAdminCommand}"
                    Margin="0,0,0,12"
                    Content="{Binding RestartAsAdminLabel}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource SuccessBrush}"
                       FontSize="13"
                       Margin="0,0,0,16"
                       TextWrapping="Wrap"/>

            <!-- 2×2 preset grid -->
            <ItemsControl ItemsSource="{Binding Presets}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:BoostCard Preset="{Binding}"
                                            ApplyCommand="{Binding DataContext.ApplyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            MoreTweaksLabel="{Binding DataContext.MoreTweaksLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            RestoreRecommendedLabel="{Binding DataContext.RestoreRecommendedLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            Margin="0,0,16,16"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
