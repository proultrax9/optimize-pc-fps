<Window x:Class="FpsGodPc.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FpsGodPc.App.ViewModels;assembly=FpsGodPc.ViewModels"
        Title="FPS Optimize GOD PC"
        Icon="pack://application:,,,/Assets/app.ico"
        MinWidth="1280"
        MinHeight="800"
        Width="1360"
        Height="860"
        Background="{StaticResource AppBgBrush}"
        FontFamily="{StaticResource AppFont}"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Admin banner -->
        <Border Grid.Row="0" Background="#22FBBF24" BorderBrush="#55FBBF24" BorderThickness="0,0,0,1" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <TextBlock Text="{Binding AdminBannerText}" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                        Content="{Binding RestartAdminLabel}"
                        Margin="12,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding RestartElevatedCommand}"/>
            </DockPanel>
        </Border>

        <!-- Watchdog banner -->
        <Border Grid.Row="1" Background="#22F87171" BorderBrush="#55F87171" BorderThickness="0,0,0,1" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasWatchdogMessage}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{Binding DismissWatchdogLabel}"
                        Margin="12,0,0,0"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding DismissWatchdogCommand}"/>
                <TextBlock Text="{Binding WatchdogMessage}" Foreground="{StaticResource DangerBrush}" TextWrapping="Wrap" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Confirm timer banner -->
        <Border Grid.Row="2" Background="#222A1F0A" BorderBrush="#55FBBF24" BorderThickness="0,0,0,1" Padding="18,12">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasConfirmTimer}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="{Binding ConfirmTimerKeepLabel}"
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding KeepPendingTweaksCommand}"/>
                    <Button Content="{Binding ConfirmTimerRevertLabel}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RejectPendingTweaksCommand}"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding ConfirmTimerTitle}" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                    <TextBlock Text="{Binding ConfirmTimerMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===================== SIDEBAR ===================== -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <DockPanel Margin="12,20,12,12">
                    <!-- Brand -->
                    <StackPanel DockPanel.Dock="Top" Margin="8,0,0,20">
                        <TextBlock Text="FPS Optimize"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="GOD PC"
                                   FontSize="10"
                                   FontWeight="Medium"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>

                    <!-- Nav -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding NavigationSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:NavSectionViewModel}">
                                    <StackPanel Margin="0,0,0,14">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="8,0,0,6">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsFooter}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Title}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:NavEntryViewModel}">
                                                    <Button Margin="0,2"
                                                            Padding="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding Key}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="navRoot"
                                                                        CornerRadius="6"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="1"
                                                                        Padding="12,8">
                                                                    <TextBlock x:Name="navText"
                                                                               Text="{Binding Label}"
                                                                               FontSize="13"
                                                                               FontWeight="Medium"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="navRoot" Property="Background" Value="{StaticResource ElevatedBrush}"/>
                                                                        <Setter TargetName="navText" Property="Foreground" Value="{StaticResource TextBrush}"/>
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter TargetName="navRoot" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                                                        <Setter TargetName="navRoot" Property="BorderBrush" Value="{StaticResource AccentMutedBrush}"/>
                                                                        <Setter TargetName="navText" Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentPage}"
                            Background="{StaticResource HeroGlowBrush}"/>
        </Grid>
    </Grid>
</Window>
